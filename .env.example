# ─── Core ───────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/monadcore?schema=public"

# Server port (default: 3000)
PORT=3000

# Environment: development | production | test
NODE_ENV=development

# ─── Monad Network ─────────────────────────────────────────
# Monad testnet RPC endpoint
MONAD_RPC_URL=

# Private key for contract deployment (NEVER commit real keys)
MONAD_PRIVATE_KEY=

# ─── AI / Gemini ────────────────────────────────────────────
# Google Gemini API key for AI-powered analysis
GEMINI_API_KEY=

# ─── GitHub OAuth ───────────────────────────────────────────
# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Auth ───────────────────────────────────────────────────
# JWT signing secret
JWT_SECRET=

# ─── Engine ─────────────────────────────────────────────────
# Path to the compiled Rust engine binary
ENGINE_BINARY_PATH=

# ─── Frontend ───────────────────────────────────────────────
# Frontend URL for CORS origin (required in production)
FRONTEND_URL=http://localhost:3001
